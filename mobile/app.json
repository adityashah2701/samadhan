{
  "expo": {
    "name": "Samadhan",
    "slug": "samadhan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "scheme": "samadhan",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "developmentClient": {
      "silentLaunch": true
    },
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.adityashah27.samadhan",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "This app needs your location to tag civic issues accurately.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app needs your location to provide relevant updates and tag civic issues accurately.",
        "NSCameraUsageDescription": "This app needs access to your camera to let you take photos of civic issues.",
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to let you upload images of civic issues."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.adityashah27.samadhan",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0f172a",
          "dark": {
            "image": "./assets/logo.png",
            "backgroundColor": "#0f172a"
          }
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      "expo-location"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e7b433c9-4b7c-4b8e-bbfc-453d36608c00"
      }
    }
  }
}